{
  "name": "rspress-plugin-obsidian-wikilink",
  "version": "0.0.1",
  "description": "Obsidian-style wikilinks for Rspress.",
  "keywords": [
    "rspress",
    "obsidian",
    "wikilink",
    "wiki-links",
    "remark",
    "markdown"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jacob-Valor/rspress-plugin-obsidian-wikilink.git"
  },
  "bugs": {
    "url": "https://github.com/Jacob-Valor/rspress-plugin-obsidian-wikilink/issues"
  },
  "homepage": "https://github.com/Jacob-Valor/rspress-plugin-obsidian-wikilink#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "docs:dev": "bunx rspress dev",
    "docs:build": "bunx rspress build"
  },
  "dependencies": {
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "rspress-plugin-devkit": "^1.0.0",
    "typescript": "^6.0.2",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.8",
    "typescript": "^6.0.2"
  }
}
