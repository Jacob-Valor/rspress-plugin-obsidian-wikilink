{
	"name": "rspress-plugin-obsidian-wikilink",
	"version": "0.1.1",
	"description": "Obsidian-style wikilinks, callouts, backlinks, transclusion, tags, and footnotes for Rspress. Write your docs in Obsidian, publish with Rspress.",
	"keywords": [
		"rspress",
		"rspress-plugin",
		"obsidian",
		"wikilink",
		"wiki-links",
		"remark",
		"remark-plugin",
		"markdown",
		"mdast",
		"backlinks",
		"callouts",
		"transclusion",
		"docs",
		"static-site",
		"rsbuild"
	],
	"license": "MIT",
	"author": "Jacob Valor",
	"type": "module",
	"sideEffects": [
		"*.css",
		"./dist/styles.css"
	],
	"files": [
		"dist",
		"LICENSE",
		"README.md",
		"CHANGELOG.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Jacob-Valor/rspress-plugin-obsidian-wikilink.git"
	},
	"bugs": {
		"url": "https://github.com/Jacob-Valor/rspress-plugin-obsidian-wikilink/issues"
	},
	"homepage": "https://github.com/Jacob-Valor/rspress-plugin-obsidian-wikilink#readme",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles.css": "./dist/styles.css",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "bun run scripts/build.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/ tests/",
		"lint:fix": "biome check --write src/ tests/",
		"format": "biome format --write src/ tests/",
		"format:check": "biome format src/ tests/",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"pretest": "bun run build",
		"prepublishOnly": "bun run build && bun run typecheck && bun test",
		"docs:dev": "bunx rspress dev",
		"docs:build": "bunx rspress build",
		"release": "semantic-release --no-ci",
		"release:dry": "semantic-release --no-ci --dry-run",
		"postrelease": "git fetch origin main:refs/remotes/origin/main --no-tags || true"
	},
	"dependencies": {
		"github-slugger": "^2.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/exec": "^6.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^11.0.6",
		"@semantic-release/npm": "^11.0.2",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/bun": "latest",
		"remark-parse": "^11.0.0",
		"remark-stringify": "^11.0.0",
		"rspress-plugin-devkit": "^1.0.0",
		"semantic-release": "^25.0.3",
		"typescript": "^6.0.2",
		"unified": "^11.0.5"
	},
	"peerDependencies": {
		"@rspress/core": "^2.0.8",
		"typescript": "^5.0.0 || ^6.0.0"
	},
	"engines": {
		"node": ">=22.14.0"
	}
}
